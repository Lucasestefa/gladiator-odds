# ══════════════════════════════════════════════════════
# GLADIATOR ODDS — Variables de entorno
# Copiá este archivo a .env y completá los valores
# NUNCA subas el .env a git
# ══════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=cambia-esto-en-produccion
FRONTEND_URL=http://localhost:3000

# ── Base de datos ─────────────────────────────────────
DB_PASSWORD=gladiator2024
DATABASE_URL=postgresql://postgres:gladiator2024@localhost:5432/gladiator_odds

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=cambia-esto-tambien

# ── The Odds API ──────────────────────────────────────
# Obtener en: https://the-odds-api.com
# Plan gratuito: 500 requests/mes
# Plan básico: $30/mes → 100k requests
ODDS_API_KEY=

# ── Betfair API ───────────────────────────────────────
# Obtener en: https://developer.betfair.com
# Requiere cuenta verificada + solicitar acceso API
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_PATH=./certs/betfair.crt
BETFAIR_KEY_PATH=./certs/betfair.key

# ── Twilio WhatsApp (GL2) ─────────────────────────────
# Obtener en: https://twilio.com
# Costo: ~$0.005 por mensaje WA
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Stripe (pagos globales) ───────────────────────────
# Obtener en: https://stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Crear productos en Stripe dashboard y pegar IDs:
STRIPE_PRICE_WA=price_...       # $9/mes
STRIPE_PRICE_STARTER=price_...  # $15/mes
STRIPE_PRICE_PRO=price_...      # $39/mes
STRIPE_PRICE_ELITE=price_...    # $89/mes

# ── MercadoPago (Argentina) ───────────────────────────
# Obtener en: https://mercadopago.com.ar/developers
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=

# ── Anthropic (IA) ────────────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── n8n (GL3 - Gladiator Automate) ───────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=
